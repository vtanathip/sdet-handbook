{
  "name": "claude-token-tracker",
  "version": "1.0.0",
  "description": "Local dashboard to track Claude token usage and file storage",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "stop": "kill-port 3000"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "kill-port": "^2.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
