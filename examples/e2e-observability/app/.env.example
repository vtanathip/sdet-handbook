# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# ── PostgreSQL (RDS) ────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=todos
PGUSER=todos
PGPASSWORD=changeme

# ── Datadog APM / Continuous Profiler ──────────────────────────────────────
DD_API_KEY=your-datadog-api-key
DD_ENV=perf-test
DD_SERVICE=todo-api
DD_VERSION=1.0.0
DD_PROFILING_ENABLED=true
DD_LOGS_INJECTION=true
