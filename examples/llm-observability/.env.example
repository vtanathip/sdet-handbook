# =============================================================================
# LLM Provider Selection
# =============================================================================
# Options: "ollama" or "azure_openai"
LLM_PROVIDER=ollama

# =============================================================================
# Ollama Configuration (when LLM_PROVIDER=ollama)
# =============================================================================
# URL of Ollama server (use host.docker.internal when running in Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# Azure OpenAI Configuration (when LLM_PROVIDER=azure_openai)
# =============================================================================
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# Phoenix / OpenTelemetry Configuration
# =============================================================================
# Phoenix collector endpoint (OTLP gRPC)
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
# Service name shown in Phoenix UI
OTEL_SERVICE_NAME=llm-observability-chatbot

# =============================================================================
# Chatbot Configuration
# =============================================================================
SYSTEM_PROMPT=You are a helpful AI assistant. Be concise and informative.
