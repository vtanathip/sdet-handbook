GITLAB_URL=http://gitlab:8080
GITLAB_TOKEN=replace-with-local-gitlab-token
PROJECT_IDS=replace-with-local-project-id
TARGET_BRANCH=main
POLL_INTERVAL_SECONDS=900
BOT_BRANCH_PREFIX=bot/scan
BOT_COMMIT_AUTHOR_NAME=GitLab Security Bot
BOT_COMMIT_AUTHOR_EMAIL=gitlab-bot@example.com
MAX_FILES_CHANGED=200
AUTO_FIX_RUFF=true
AUTO_FIX_DEPENDENCIES=false
STATE_FILE=/data/state.json
DRY_RUN=false
