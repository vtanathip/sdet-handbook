# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Target Application
BASE_URL=
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Observability (Phoenix)
PHOENIX_ENDPOINT=http://localhost:6006

# Behaviour Tuning
AI_CONFIDENCE_THRESHOLD=0.6
AI_MAX_RETRIES=2
SCREENSHOT_ON_FAILURE=true
DOM_MAX_TOKENS=4000
TABLE_MAX_SCROLL_ATTEMPTS=10

# Debug Mode
DOM_HIGHLIGHT=true
DOM_SNAPSHOT=true
DOM_DEBUG=true
DOM_HIGHLIGHT_PAUSE=1200   # longer pause before action (ms)
DOM_HIGHLIGHT_DURATION=3000  # how long the overlay stays visible (ms)
